# PATH
export PATH=/opt/homebrew/bin:$HOME/.local/bin:$HOME/.lmstudio/bin:$PATH

# Editor
export EDITOR="nvim"

# Oh My Zsh + Powerlevel10k
source ~/.config/zsh/oh-my-zsh-p10k.zsh

# Aliases
alias ll="ls -la"
alias zce="$EDITOR ~/.zshrc"
alias bbi="brew bundle install --file=~/.local/share/chezmoi/.setup/Brewfile"
alias bbe="$EDITOR ~/.local/share/chezmoi/.setup/Brewfile"
alias clp='CLAUDE_CONFIG_DIR=$HOME/.claude-private claude'
alias clw='CLAUDE_CONFIG_DIR=$HOME/.claude-work claude'

# Zoxide
eval "$(zoxide init zsh)"

# SDKMAN (must be at the end)
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"
